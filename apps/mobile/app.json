{
  "expo": {
    "name": "Brew Loyalty",
    "slug": "brew-loyalty",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "brewloyalty",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.brewloyalty.app"
    },
    "android": {
      "package": "com.brewloyalty.app",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
